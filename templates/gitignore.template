# ──────────────────────────────────────────────
# Gridge AIMSP Harness — .gitignore
# Refs: 93_workflow.md § G-206
# ──────────────────────────────────────────────

# --- Node.js / npm ---
node_modules/
*.log
.npm/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- 환경 변수 (개인 / 로컬 전용) ---
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# 예외: .env.example 은 커밋 허용
!.env.example

# --- 빌드 산출물 ---
dist/
build/
out/
.next/
.nuxt/
.vite/
coverage/
*.tsbuildinfo

# --- OS / 에디터 로컬 파일 ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.recommended.json
*.swp
*.swo
*~

# --- 하네스 런타임 파일 ---

# 세션별 휘발 메타 (99_governance § 부록 B)
.context/session.yml

# Claude Code 에이전트 실행 중 자동 생성 (민감 정보 포함 가능)
.claude/issue/conflicts-*.md
.claude/issue/knowledge-*.md
.claude/issue/feedback-*.md
.claude/issue/resume-*.md
.claude/issue/transition-*.md
.claude/issue/blocked-*.md

# 예외: 디렉토리는 유지 (.gitkeep)
!.claude/issue/.gitkeep

# --- 테스트 / 임시 파일 ---
.test-output/
tmp/
temp/
*.tmp
*.bak

# --- 시크릿 / 키 (절대 커밋 금지) ---
*.pem
*.key
*.crt
secrets.json
credentials.json

# --- 대용량 이진 (Git LFS 사용) ---
*.mp4
*.mov
*.pdf
# 예외: 문서용 PDF 는 skills/*/pdf/ 에 커밋 허용
!skills/*/docs/*.pdf

# --- Python (일부 스크립트가 사용) ---
__pycache__/
*.py[cod]
*.egg-info/
venv/
.venv/

# --- 기타 ---
.sentryclirc
.turbo/
.cache/
