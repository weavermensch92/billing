# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CONSOLE_URL=http://localhost:3001

# Billing MSP
NEXT_PUBLIC_PRODUCT=billing

# Email (Resend) — lib/email/client.ts
# 트랜잭션 메일 발송 — 운영 시 필수. 미설정 시 sendEmail() 호출이 즉시 에러.
# Supabase Dashboard 의 Auth SMTP 설정 (회원 초대 메일) 과는 별개 — 거기는
# 직접 SMTP host/port/username/password 입력. 본 키는 Resend HTTPS API 용.
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM="Gridge <noreply@your-domain.com>"
